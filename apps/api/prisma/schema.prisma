generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  plan         String    @default("free")
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  activeProfileId String?

  profiles               Profile[]
  orchestrationRules     OrchestrationRule[]
  devices                Device[]
  sharedSessions         SharedScreenSession[]
  activeProfile          Profile?            @relation("UserActiveProfile", fields: [activeProfileId], references: [id], onDelete: SetNull)
  installedPlugins       InstalledPlugin[]
  authoredPlugins        Plugin[]            @relation("AuthoredPlugins")
  integrationConnections IntegrationConnection[]

  @@index([activeProfileId])
}

model IntegrationConnection {
  id                    String    @id @default(uuid())
  userId                String
  provider              String
  externalAccountId     String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenType             String    @default("Bearer")
  scopes                String[]  @default([])
  expiresAt             DateTime?
  label                 String?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, externalAccountId])
  @@index([userId])
  @@index([userId, provider])
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  name       String
  platform   String
  deviceType String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, lastSeenAt])
}

model Profile {
  id        String           @id @default(uuid())
  userId    String
  name      String
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  defaultSlideDurationSeconds Int @default(30)

  user    User             @relation(fields: [userId], references: [id])
  widgets WidgetInstance[]
  slides  Slide[]
  activeForUsers User[]    @relation("UserActiveProfile")

  @@index([userId])
}

model WidgetInstance {
  id        String   @id @default(uuid())
  profileId String
  type      String
  config    Json
  layoutX   Int      @default(0)
  layoutY   Int      @default(0)
  layoutW   Int      @default(1)
  layoutH   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile    @relation(fields: [profileId], references: [id])
  slideItem SlideItem?

  @@index([profileId])
}

model Slide {
  id                  String      @id @default(uuid())
  profileId           String
  name                String
  order               Int         @default(0)
  durationSeconds     Int?
  isEnabled           Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  slideItems SlideItem[]

  @@index([profileId])
  @@index([profileId, order])
}

model SlideItem {
  id               String   @id @default(uuid())
  slideId          String
  widgetInstanceId String   @unique
  layoutX          Int      @default(0)
  layoutY          Int      @default(0)
  layoutW          Int      @default(1)
  layoutH          Int      @default(1)
  zIndex           Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  slide          Slide          @relation(fields: [slideId], references: [id], onDelete: Cascade)
  widgetInstance WidgetInstance @relation(fields: [widgetInstanceId], references: [id], onDelete: Cascade)

  @@index([slideId])
}

model OrchestrationRule {
  id                 String   @id @default(uuid())
  userId             String
  type               String
  intervalSec        Int
  isActive           Boolean  @default(true)
  rotationProfileIds String[] @default([])
  currentIndex       Int      @default(0)
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SharedScreenSession {
  id                  String   @id @default(uuid())
  userId              String
  name                String
  isActive            Boolean  @default(true)
  activeProfileId     String?
  slideshowEnabled    Boolean  @default(false)
  slideshowIntervalSec Int     @default(60)
  rotationProfileIds  String[] @default([])
  currentIndex        Int      @default(0)
  lastAdvancedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants SharedScreenParticipant[]

  @@index([userId])
  @@index([userId, isActive])
}

model SharedScreenParticipant {
  id          String   @id @default(uuid())
  sessionId   String
  deviceId    String
  displayName String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  session SharedScreenSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, deviceId])
  @@index([sessionId])
}

model ModerationEvent {
  id         String           @id @default(uuid())
  targetType String           // "plugin" | "pluginVersion"
  targetId   String
  pluginId   String
  action     ModerationStatus // APPROVED | REJECTED
  actorId    String
  reason     String?
  createdAt  DateTime         @default(now())

  @@index([pluginId])
  @@index([targetId])
  @@index([actorId])
}

model TokenBlocklist {
  jti       String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Plugin {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String   @unique
  description String
  category    String
  authorId    String?
  isPremium        Boolean          @default(false)
  isApproved       Boolean          @default(false)
  approvedAt       DateTime?
  approvedBy       String?
  rejectionReason  String?
  status           ModerationStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  author            User?           @relation("AuthoredPlugins", fields: [authorId], references: [id], onDelete: SetNull)
  versions          PluginVersion[]
  installedByUsers  InstalledPlugin[]

  @@index([authorId])
  @@index([status])
  @@index([isApproved])
}

model InstalledPlugin {
  id          String   @id @default(uuid())
  userId      String
  pluginId    String
  isEnabled   Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([userId, pluginId])
  @@index([userId])
}

model PluginVersion {
  id           String   @id @default(uuid())
  pluginId     String
  version      String
  manifestJson Json
  entryPoint   String
  changelog    String?
  isActive        Boolean          @default(false)
  isApproved      Boolean          @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  status          ModerationStatus @default(PENDING)
  createdAt       DateTime         @default(now())

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, version])
  @@index([pluginId])
  @@index([isActive])
}
