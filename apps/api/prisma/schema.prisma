generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  plan         String    @default("free")
  createdAt    DateTime  @default(now())
  activeProfileId String?

  profiles           Profile[]
  orchestrationRules OrchestrationRule[]
  devices            Device[]
  sharedSessions     SharedScreenSession[]
  activeProfile      Profile?            @relation("UserActiveProfile", fields: [activeProfileId], references: [id], onDelete: SetNull)
  installedPlugins   InstalledPlugin[]
  authoredPlugins    Plugin[]            @relation("AuthoredPlugins")

  @@index([activeProfileId])
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  name       String
  platform   String
  deviceType String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, lastSeenAt])
}

model Profile {
  id        String           @id @default(uuid())
  userId    String
  name      String
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User             @relation(fields: [userId], references: [id])
  widgets WidgetInstance[]
  activeForUsers User[]    @relation("UserActiveProfile")

  @@index([userId])
}

model WidgetInstance {
  id        String   @id @default(uuid())
  profileId String
  type      String
  config    Json
  layoutX   Int      @default(0)
  layoutY   Int      @default(0)
  layoutW   Int      @default(1)
  layoutH   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id])

  @@index([profileId])
}

model OrchestrationRule {
  id                 String   @id @default(uuid())
  userId             String
  type               String
  intervalSec        Int
  isActive           Boolean  @default(true)
  rotationProfileIds String[] @default([])
  currentIndex       Int      @default(0)
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SharedScreenSession {
  id                  String   @id @default(uuid())
  userId              String
  name                String
  isActive            Boolean  @default(true)
  activeProfileId     String?
  slideshowEnabled    Boolean  @default(false)
  slideshowIntervalSec Int     @default(60)
  rotationProfileIds  String[] @default([])
  currentIndex        Int      @default(0)
  lastAdvancedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants SharedScreenParticipant[]

  @@index([userId])
  @@index([userId, isActive])
}

model SharedScreenParticipant {
  id          String   @id @default(uuid())
  sessionId   String
  deviceId    String
  displayName String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  session SharedScreenSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, deviceId])
  @@index([sessionId])
}

model Plugin {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String   @unique
  description String
  category    String
  authorId    String?
  isPremium   Boolean  @default(false)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author            User?           @relation("AuthoredPlugins", fields: [authorId], references: [id], onDelete: SetNull)
  versions          PluginVersion[]
  installedByUsers  InstalledPlugin[]

  @@index([authorId])
}

model InstalledPlugin {
  id          String   @id @default(uuid())
  userId      String
  pluginId    String
  isEnabled   Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([userId, pluginId])
  @@index([userId])
}

model PluginVersion {
  id           String   @id @default(uuid())
  pluginId     String
  version      String
  manifestJson Json
  entryPoint   String?
  changelog    String?
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, version])
  @@index([pluginId])
}
