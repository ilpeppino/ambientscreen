# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ambient_dev

# App
# Optional API port for local development
PORT=3000
NODE_ENV=development
AUTH_JWT_SECRET=change-me

# Weather widget (OpenWeather API)
# Required for the built-in weather widget. Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# CORS
# Comma-separated list of allowed origins for cross-origin browser requests.
# Example: http://localhost:19006,https://app.example.com
# Leave unset (or empty) to block all cross-origin requests — safe default for production.
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# Google OAuth (required for Google Calendar integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/google/callback

# Integration token encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=

# App base URL (used for OAuth redirects back to the frontend)
APP_BASE_URL=http://localhost:19006
