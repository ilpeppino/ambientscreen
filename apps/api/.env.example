# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ambient_dev

# App
# Optional API port for local development
PORT=3000
NODE_ENV=development
AUTH_JWT_SECRET=change-me

# CORS
# Comma-separated list of allowed origins for cross-origin browser requests.
# Example: http://localhost:19006,https://app.example.com
# Leave unset (or empty) to block all cross-origin requests — safe default for production.
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081
