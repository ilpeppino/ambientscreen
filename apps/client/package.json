{
  "name": "@ambient/client",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:web": "expo export --platform web --output-dir /tmp/expo-web-smoke"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.0",
    "expo-keep-awake": "~14.0.2",
    "expo-screen-orientation": "~8.0.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.77.3",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.18",
    "typescript": "~5.8.3",
    "vitest": "^3.1.1"
  }
}
