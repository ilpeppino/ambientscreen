{
  "name": "@ambient/client",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "typecheck": "tsc --noEmit",
    "check-tokens": "node scripts/check-tokens.js",
    "check-modals": "node ../../scripts/check-modal-usage.js",
    "lint": "tsc --noEmit && node scripts/check-tokens.js && node ../../scripts/check-modal-usage.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:web": "expo export --platform web --output-dir /tmp/expo-web-smoke"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@shopify/flash-list": "2.0.2",
    "expo": "~54.0.0",
    "expo-keep-awake": "~15.0.8",
    "expo-screen-orientation": "~9.0.8",
    "lucide-react-native": "^0.577.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
"devDependencies": {
  "@types/react": "~19.1.0",
  "@types/react-test-renderer": "19.1.0",
  "@vitest/coverage-v8": "^3.2.4",
  "react-test-renderer": "19.1.0",
  "typescript": "~5.9.2",
  "vitest": "^3.1.1"
}
}
